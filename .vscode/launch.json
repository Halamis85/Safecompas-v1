{
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run vite",
            "runtimeExecutable": "vite",
            "cwd": "${workspaceFolder}",
            "args": []
        },
        {
            "name": "Spustit vestavěný server a ladit",
            "detail": "Launch development server with router, and start debug (Root: \"public\")",
            "type": "php",
            "request": "launch",
            "noDebug": false,
            "runtimeArgs": [
                "-S",
                "localhost:8000",
                "-t",
                ".",
                "../vendor/laravel/framework/src/Illuminate/Foundation/resources/server.php"
            ],
            "cwd": "${workspaceRoot}/public",
            "serverReadyAction": {
                "action": "openExternally"
            },
            "envFile": "../.env"
        }
    ]
}